generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  code               String?  @unique
  description        String?
  logo               String?
  colorIndicator     String?  @default("#10b981")
  contactPerson      String?  @db.Text
  address            String?  @db.Text
  registrationNumber String?
  contactEmail       String?
  contactPhone       String?
  dynamicDetails     Json?
  signature          String?  @db.Text
  seal               String?  @db.Text
  conditions         String?  @db.Text
  
  // Bank Details
  bankName           String?
  accountNumber      String?
  ifscCode           String?
  branch             String?
  accountName        String?
  
  isBlocked          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users                  User[]
  kpiEntries             KpiEntry[]
  financeMetrics         FinanceMetrics[]
  salesMetrics           SalesMetrics[]
  manufacturingMetrics   ManufacturingMetrics[]
  supplyChainMetrics     SupplyChainMetrics[]
  supportMetrics         SupportMetrics[]
  hrMetrics              HrMetrics[]
  financeFundValues      FinanceFundValue[]
  hierarchyNodes         HierarchyNode[]
  CategoryMaster         CategoryMaster[]
  CustomerCategoryMaster CustomerCategoryMaster[]
  PaymentTypeMaster      PaymentTypeMaster[]
  CustomerMaster         CustomerMaster[]
  SupplierMaster         SupplierMaster[]
  ZoneMaster             ZoneMaster[]
  StatusMaster           StatusMaster[]
  StageMaster            StageMaster[]
  RequestStageMaster     RequestStageMaster[]
  TargetMaster           TargetMaster[]
  SupportTicket          SupportTicket[]
  SupplyRequest          SupplyRequest[]
  Tasks                  Task[]
  VaultDocuments         VaultDocument[]

  PoWorkflowMaster      PoWorkflowMaster[]
  PurchaseOrderRequest  PurchaseOrderRequest[]
  InventoryOrder        InventoryOrder[]
  ExpenseCategoryMaster ExpenseCategoryMaster[]
  CurrencyMaster        CurrencyMaster[]
  Expense               Expense[]
  TimeEntry             TimeEntry[]
  Role                  Role[]
  DocumentTemplates     DocumentTemplate[]
}

model DocumentTemplate {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  name        String   // Template Name
  docType     String   // "PO", "INVOICE", "QUOTATION", etc.
  layoutConfig Json     // Detailed layout JSON
  isDefault   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
}

model HierarchyNode {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Position Details
  title String // e.g., "CEO", "Head of Sales"

  // Person Details (Optional)
  name     String?
  email    String?
  phone    String?
  location String?
  photo    String? // Base64 or URL

  // Tree Structure
  parentId String?
  parent   HierarchyNode?  @relation("Tree", fields: [parentId], references: [id])
  children HierarchyNode[] @relation("Tree")

  order Int @default(0) // For sorting siblings

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model KpiEntry {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  category  String // "Finance", "Sales", "Manufacturing", etc.
  metric    String // "Cash Inflow", "Accounts Receivable", etc.
  date      DateTime // Representative date for the period
  period    String // "Weekly", "Monthly", "Quarterly", "Annual"
  value     Float
  target    Float?
  status    String? // "Critical", "On Track", etc.
  meta      Json? // For deep dive data
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, period, date])
  @@index([companyId])
}

model User {
  id                 String    @id @default(cuid())
  userType           String    @default("Entity") // "Entity" | "Group"
  hasGlobalAccess    Boolean   @default(false)
  hasVaultAccess     Boolean   @default(false)
  companies          Company[]
  email              String    @unique
  username           String?   @unique
  firstName          String?
  lastName           String?
  profileName        String?
  password           String // Hashed password
  image              String? // Avatar URL or Base64
  phoneNumber        String?
  notificationEmails String?   @db.Text
  primaryManagerId   String?
  secondaryManagerId String?

  roleId    String?
  role      Role?   @relation(fields: [roleId], references: [id])
  isBlocked Boolean @default(false)

  isTempPassword   Boolean   @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  opportunities Opportunity[]
  SupportTicket SupportTicket[]
  SupplyRequest SupplyRequest[]

  assignedTasks     Task[]          @relation("AssignedTo")
  createdTasks      Task[]          @relation("AssignedBy")
  TaskComment       TaskComment[]
  uploadedVaultDocs VaultDocument[]

  sentMessages     Message[]   @relation("SentMessages")
  receivedMessages Message[]   @relation("ReceivedMessages")
  Expense          Expense[]
  TimeEntry        TimeEntry[]

  PoWorkflowStep       PoWorkflowStep[]
  PurchaseOrderRequest PurchaseOrderRequest[] @relation("PoCreator")
  PoApprovalHistory    PoApprovalHistory[]

  @@index([hasGlobalAccess])
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content    String?  @db.Text
  attachment Json? // Array of files {name, type, data: base64}
  readStatus Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([senderId, receiverId])
}

model FinanceFundValue {
  id        Int      @id @default(autoincrement())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  date      DateTime
  fundValue Float
  utilised  Float
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model FinanceMetrics {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  period    String // "Weekly", "Monthly", "Quarterly", "Annual"
  date      DateTime // For filtering (start date of period)

  // KPIs
  revenue  Float @default(0)
  expenses Float @default(0)
  profit   Float @default(0) // Net

  // Cash Flow
  inflow          Float @default(0)
  outflow         Float @default(0)
  cashBalance     Float @default(0)
  prevInflow      Float @default(0)
  prevOutflow     Float @default(0)
  prevCashBalance Float @default(0)

  // AR / AP Deep Dive
  arTotal      Float @default(0)
  arCurrent    Float @default(0)
  ar0to30      Float @default(0)
  ar30to60     Float @default(0)
  ar60to90plus Float @default(0)

  apTotal      Float @default(0)
  apCurrent    Float @default(0)
  ap0to30      Float @default(0)
  ap30to60     Float @default(0)
  ap60to90plus Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model SalesMetrics {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  period    String // "Weekly", "Monthly", "Quarterly", "Annual"
  date      DateTime // For filtering (start date of period)

  // Targets & YTD
  annualTarget  Float @default(0)
  ordersYtdPct  Float @default(0) // Percentage 0-100
  invoiceYtdPct Float @default(0) // Percentage 0-100

  // Funnel (Quantity)
  leadsCount       Int @default(0)
  rfqCount         Int @default(0)
  quotesCount      Int @default(0)
  negotiationCount Int @default(0)
  orderCount       Int @default(0)

  // Funnel (Value)
  quotesValue      Float @default(0)
  negotiationValue Float @default(0)
  winValue         Float @default(0)
  lossValue        Float @default(0) // For analysis

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model ManufacturingMetrics {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  period    String // "Weekly", "Monthly", "Quarterly", "Annual"
  date      DateTime

  // RFQ Analytics
  rfqNew      Int @default(0) // This week
  rfqStandard Int @default(0)
  rfqCustom   Int @default(0)

  // Project Status Deep Dive
  projectOnTrack        Int @default(0)
  projectBehindSchedule Int @default(0)
  projectCritical       Int @default(0)

  // Efficiency
  efficiency Float @default(0) // Percentage

  // Order Fulfilment Override Integration
  orderValue       Float? // Manually input value, fallback to Sales 'winValue'
  productionVolume Int? // Manually input volume, fallback to Sales 'orderCount'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model SupplyChainMetrics {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  period    String
  date      DateTime

  // Payment Status
  outstandingPayments Float @default(0)

  // Sourcing Nodes
  domesticSource Int @default(0)
  intlSource     Int @default(0)

  // Payment Terms Deep Dive
  totalSuppliers   Int @default(0)
  cashAdvanceTerms Int @default(0)
  net15Terms       Int @default(0)
  net30Terms       Int @default(0)
  net60Terms       Int @default(0)
  net90Terms       Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model SupportMetrics {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  period    String
  date      DateTime

  totalTickets    Int   @default(0)
  openTickets     Int   @default(0)
  criticalIssues  Int   @default(0)
  resolvedTickets Int   @default(0)
  avgResponseTime Float @default(0) // Hours

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model HrMetrics {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  period    String
  date      DateTime

  // Org Strength
  orgStrength Int @default(0)

  // Open Positions Deep dive
  openPosLagging Int @default(0)
  openPosOnTrack Int @default(0)

  // Recruitment Funnel
  recruitedApplied   Int @default(0)
  recruitedScreening Int @default(0)
  recruitedInterview Int @default(0)
  recruitedOffer     Int @default(0)
  recruitedHired     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String // "LOGIN", "CREATE_USER", "UPDATE_SETTINGS", etc.
  entity    String // "User", "System", "Invoice", etc.
  entityId  String? // ID of the affected entity
  details   Json? // Flexible JSON
  userId    String? // ID of the user performing the action
  userEmail String? // Redundant email storage
  ipAddress String?
  createdAt DateTime @default(now())
}

// -----------------------------------------------------------------------------
// CONFIGURATION MASTERS
// -----------------------------------------------------------------------------

model CategoryMaster {
  slno         Int      @id @default(autoincrement())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  categoryName String
  remarks      String?
  isActive     Boolean  @default(true)
  isDelete     Boolean  @default(false)

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  opportunities Opportunity[]

  @@unique([companyId, categoryName])
}

model CustomerCategoryMaster {
  slno         Int      @id @default(autoincrement())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  categoryName String
  description  String?
  isActive     Boolean  @default(true)
  isDelete     Boolean  @default(false)

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  customers CustomerMaster[] @relation("CustomerCategories")
  suppliers SupplierMaster[] @relation("SupplierCategories")

  @@unique([companyId, categoryName])
}

model PaymentTypeMaster {
  slno        Int      @id @default(autoincrement())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  paymentType String
  remarks     String?
  isActive    Boolean  @default(true)
  isDelete    Boolean  @default(false)

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  customers      CustomerMaster[]
  suppliers      SupplierMaster[]
  opportunities  Opportunity[]
  InventoryOrder InventoryOrder[]

  @@unique([companyId, paymentType])
}

model CustomerMaster {
  slno         Int      @id @default(autoincrement())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  customerName String
  remarks      String?
  usb          String?
  isActive     Boolean  @default(true)
  isDelete     Boolean  @default(false)

  paymentTypeId Int?
  paymentType   PaymentTypeMaster? @relation(fields: [paymentTypeId], references: [slno])

  categories CustomerCategoryMaster[] @relation("CustomerCategories")
  contacts   CustomerContact[]
  addresses  CustomerAddress[]

  createdAt DateTime @default(now())
  createdBy String?
  updatedAt DateTime @updatedAt
  updatedBy String?

  opportunities Opportunity[]

  @@unique([companyId, customerName])
}

model CustomerContact {
  id           String         @id @default(cuid())
  customerSlno Int
  customer     CustomerMaster @relation(fields: [customerSlno], references: [slno], onDelete: Cascade)

  contactPerson String
  contactEmail  String?
  contactNumber String?
}

model CustomerAddress {
  id           String         @id @default(cuid())
  customerSlno Int
  customer     CustomerMaster @relation(fields: [customerSlno], references: [slno], onDelete: Cascade)

  addressName String
  address     String
}

model SupplierMaster {
  slno         Int      @id @default(autoincrement())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  supplierName String
  remarks      String?
  usb          String?
  isActive     Boolean  @default(true)
  isDelete     Boolean  @default(false)

  paymentTypeId Int?
  paymentType   PaymentTypeMaster? @relation(fields: [paymentTypeId], references: [slno])

  categories CustomerCategoryMaster[] @relation("SupplierCategories")
  contacts   SupplierContact[]
  addresses  SupplierAddress[]

  createdAt            DateTime               @default(now())
  createdBy            String?
  updatedAt            DateTime               @updatedAt
  updatedBy            String?
  InventoryOrder       InventoryOrder[]
  SupplyRequest        SupplyRequest[]
  PurchaseOrderRequest PurchaseOrderRequest[]

  @@unique([companyId, supplierName])
}

model SupplierContact {
  id           String         @id @default(cuid())
  supplierSlno Int
  supplier     SupplierMaster @relation(fields: [supplierSlno], references: [slno], onDelete: Cascade)

  contactPerson String
  contactEmail  String?
  contactNumber String?
}

model SupplierAddress {
  id           String         @id @default(cuid())
  supplierSlno Int
  supplier     SupplierMaster @relation(fields: [supplierSlno], references: [slno], onDelete: Cascade)

  addressName String
  address     String
}

model ZoneMaster {
  slno          Int           @id @default(autoincrement())
  companyId     String?
  company       Company?      @relation(fields: [companyId], references: [id])
  zoneName      String
  remarks       String?
  isActive      Boolean       @default(true)
  isDelete      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  createdBy     String?
  updatedBy     String?
  opportunities Opportunity[]

  @@unique([companyId, zoneName])
}

model StatusMaster {
  slno          Int                        @id @default(autoincrement())
  companyId     String?
  company       Company?                   @relation(fields: [companyId], references: [id])
  statusName    String
  order         Int
  remarks       String?
  isActive      Boolean                    @default(true)
  isDelete      Boolean                    @default(false)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  createdBy     String?
  updatedBy     String?
  opportunities Opportunity[]
  histories     OpportunityStatusHistory[]

  @@unique([companyId, statusName])
  @@unique([companyId, order])
}

model StageMaster {
  slno       Int      @id @default(autoincrement())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  stageName  String
  order      Int
  percentage Int      @default(0)
  remarks    String?
  isActive   Boolean  @default(true)
  isDelete   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?

  orders         Order[]
  orderHistories OrderHistory[]

  @@unique([companyId, stageName])
  @@unique([companyId, order])
}

model RequestStageMaster {
  slno       Int      @id @default(autoincrement())
  companyId  String?
  company    Company? @relation(fields: [companyId], references: [id])
  statusName String
  order      Int
  remarks    String?
  isActive   Boolean  @default(true)
  isDelete   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?

  supplyRequests SupplyRequest[]

  @@unique([companyId, statusName])
  @@unique([companyId, order])
}

model InventoryMaster {
  id          String  @id @default(cuid())
  companyId   String?
  type        String // "Individual Item" | "Sub Assembly"
  name        String
  categoryId  Int?
  hsnCode     String?
  description String?
  unit        String?
  rate        Float   @default(0)
  gst         String?
  igst        String?
  quantity    Float   @default(1)

  // File URLs can be stored as JSON array of strings
  annexures Json?
  images    Json?

  isActive  Boolean  @default(true)
  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  components InventorySubComponent[]
}

model InventorySubComponent {
  id                String          @id @default(cuid())
  inventoryMasterId String
  inventoryMaster   InventoryMaster @relation(fields: [inventoryMasterId], references: [id], onDelete: Cascade)

  componentName String
  qty           Float  @default(1)
  rate          Float  @default(0)
  total         Float  @default(0)
}

model LookupMaster {
  id        String   @id @default(cuid())
  type      String // e.g. "UNIT", "GST", "IGST"
  value     String // e.g. "kg", "18"
  label     String? // e.g. "Kilograms", "18%"
  remarks   String?
  isActive  Boolean  @default(true)
  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
}

model Opportunity {
  id              String            @id @default(cuid())
  slno            Int               @unique @default(autoincrement())
  oppNumber       String?           @unique
  date            DateTime
  opportunityName String
  customerId      Int
  customer        CustomerMaster    @relation(fields: [customerId], references: [slno])
  categories      CategoryMaster[]
  value           Float
  paymentTypeId   Int
  paymentType     PaymentTypeMaster @relation(fields: [paymentTypeId], references: [slno])
  zoneId          Int
  zone            ZoneMaster        @relation(fields: [zoneId], references: [slno])
  statusId        Int
  status          StatusMaster      @relation(fields: [statusId], references: [slno])
  inchargeId      String
  incharge        User              @relation(fields: [inchargeId], references: [id])
  remarks         String?
  createdAt       DateTime          @default(now())
  isDelete        Boolean           @default(false)

  comments       OpportunityComment[]
  histories      OpportunityStatusHistory[]
  order          Order?
  supportTickets SupportTicket[]
  supplyRequests SupplyRequest[]
}

model OpportunityStatusHistory {
  id            String       @id @default(cuid())
  opportunityId String
  opportunity   Opportunity  @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  statusId      Int
  status        StatusMaster @relation(fields: [statusId], references: [slno])
  startDate     DateTime     @default(now())
  endDate       DateTime?
  daysSpent     Int?
  remarks       String?
}

model OpportunityComment {
  id            String      @id @default(cuid())
  opportunityId String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  comment       String
  createdDate   DateTime    @default(now())
  createdBy     String
}

model Order {
  id               String           @id @default(cuid())
  orderNo          String           @unique
  opportunityId    String           @unique
  opportunity      Opportunity      @relation(fields: [opportunityId], references: [id])
  date             DateTime
  targetDate       DateTime?
  orderIncharge    String?
  orderValue       Float? // Explicit override for the value of this single order
  currentStageId   Int?
  currentStage     StageMaster?     @relation(fields: [currentStageId], references: [slno])
  history          OrderHistory[]
  isClosed         Boolean          @default(false)
  closeReason      String?
  closeAttachments Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdBy        String?
  updatedBy        String?
  SupportTicket    SupportTicket[]
  InventoryOrder   InventoryOrder[]
  SupplyRequest    SupplyRequest[]
  Tasks            Task[]
  TimeEntries      TimeEntry[]
}

model OrderHistory {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stageId     Int
  stage       StageMaster @relation(fields: [stageId], references: [slno])
  startDate   DateTime
  endDate     DateTime?
  enteredBy   String
  remarks     String?
  attachments Json?
  createdAt   DateTime    @default(now())
}

model TargetMaster {
  id            String  @id @default(cuid())
  companyId     String
  company       Company @relation(fields: [companyId], references: [id])
  category      String // e.g. "sales"
  financialYear String // e.g., "2025-26"

  // Monthly Breakdown
  apr Float @default(0)
  may Float @default(0)
  jun Float @default(0)
  jul Float @default(0)
  aug Float @default(0)
  sep Float @default(0)
  oct Float @default(0)
  nov Float @default(0)
  dec Float @default(0)
  jan Float @default(0)
  feb Float @default(0)
  mar Float @default(0)

  totalTarget Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, category, financialYear])
}

model SupportTicket {
  id         String    @id @default(cuid())
  ticketNo   String    @unique
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  type       String // "INTERNAL" | "EXTERNAL"
  date       DateTime
  details    String
  targetDate DateTime?
  actualDays Int?
  inchargeId String?
  incharge   User?     @relation(fields: [inchargeId], references: [id])

  // Only for EXTERNAL tickets
  orderId       String?
  order         Order?       @relation(fields: [orderId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  status           String    @default("OPEN") // "OPEN" | "COMPLETED" | "CLOSED"
  isClosed         Boolean   @default(false)
  closedDate       DateTime?
  closeReason      String?
  closeAttachments Json?

  comments    Json?
  attachments Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
}

model InventoryOrder {
  id               String             @id @default(uuid())
  orderNumber      String
  date             DateTime
  details          String?            @db.Text
  supplierSlno     Int
  supplier         SupplierMaster     @relation(fields: [supplierSlno], references: [slno])
  companyId        String?
  company          Company?           @relation(fields: [companyId], references: [id])
  paymentTypeId    Int?
  paymentType      PaymentTypeMaster? @relation(fields: [paymentTypeId], references: [slno])
  expectedDelivery DateTime?
  conditions       String?            @db.Text
  remarks          String?            @db.Text
  total            Float
  status           String             @default("Pending")
  receiveStatus    String?
  receivedOn       DateTime?

  type    String  @default("INTERNAL")
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  items InventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model InventoryItem {
  id               String         @id @default(uuid())
  inventoryOrderId String
  inventoryOrder   InventoryOrder @relation(fields: [inventoryOrderId], references: [id], onDelete: Cascade)
  name             String
  price            Float
  quantity         Float
  tax              Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupplyRequest {
  id         String    @id @default(cuid())
  requestNo  String    @unique
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id])
  date       DateTime
  details    String
  targetDate DateTime?
  actualDays Int?
  inchargeId String?
  incharge   User?     @relation(fields: [inchargeId], references: [id])

  type          String       @default("INTERNAL") // INTERNAL | EXTERNAL
  orderId       String?
  order         Order?       @relation(fields: [orderId], references: [id])
  opportunityId String?
  opportunity   Opportunity? @relation(fields: [opportunityId], references: [id])

  supplierSlno Int?
  supplier     SupplierMaster? @relation(fields: [supplierSlno], references: [slno])

  // Pipeline Tracking
  currentStageSlno Int?
  stage            RequestStageMaster? @relation(fields: [currentStageSlno], references: [slno])
  status           String              @default("OPEN")
  isClosed         Boolean             @default(false)
  closedDate       DateTime?
  closeReason      String?
  closeAttachments Json?

  // JSON Audit Trails
  stageHistory Json? // [{ stageSlno, stageName, order, date, remarks, attachments, updatedBy }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?

  @@index([companyId])
}

model Task {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title        String?
  description  String
  assignedById String
  assignedBy   User          @relation("AssignedBy", fields: [assignedById], references: [id])
  assignedToId String
  assignedTo   User          @relation("AssignedTo", fields: [assignedToId], references: [id])
  function     String
  projectId    String?
  project      Order?        @relation(fields: [projectId], references: [id])
  otherProject String?
  startDate    DateTime?
  dueDate      DateTime
  estimatedHrs Float?
  attachments  Json?
  priority     String        @default("medium") // low, medium, high
  status       String        @default("Pending") // Pending, In Progress, Completed, Overdue
  completedAt  DateTime?
  comments     TaskComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([assignedToId])
}

model TaskComment {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comment     String
  attachments Json? // array of base64 strings or URLs
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([taskId])
}

model VaultDocument {
  id        String  @id @default(cuid())
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category  String // Budgetary estimates, Quotations, Invoice, etc.
  fileName  String
  fileData  String // Base64 or Object URL

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  description String?
  aiTags      Json? // To support "generation / questioning" in future

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([category])
}

model Role {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String   @unique
  userType  String   @default("Entity") // "Entity" | "Group"
  remarks   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  roleAccesses RoleAccess[]
}

model AppPage {
  id       String  @id @default(cuid())
  pageName String
  remarks  String?
  isActive Boolean @default(true)
  path     String? // e.g. /hr, /supply-chain
  icon     String? // Lucide icon name string

  parentId String?
  parent   AppPage?  @relation("PageHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children AppPage[] @relation("PageHierarchy")

  roleAccesses RoleAccess[]

  orderIndex Int      @default(0) // To manage sidebar sequence
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RoleAccess {
  id String @id @default(cuid())

  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  pageId String
  page   AppPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  canView   Boolean @default(false)
  canAdd    Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, pageId])
}

model ExpenseCategoryMaster {
  slno         Int      @id @default(autoincrement())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  categoryName String
  description  String?
  isActive     Boolean  @default(true)
  isDelete     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses Expense[]

  @@unique([companyId, categoryName])
}

model CurrencyMaster {
  slno         Int      @id @default(autoincrement())
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  currencyName String
  shortName    String
  symbol       String
  isActive     Boolean  @default(true)
  isDelete     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expenses Expense[]

  @@unique([companyId, currencyName])
}

model Expense {
  id              String                @id @default(cuid())
  slno            Int                   @unique @default(autoincrement())
  companyId       String?
  company         Company?              @relation(fields: [companyId], references: [id])
  userId          String
  user            User                  @relation(fields: [userId], references: [id])
  date            DateTime
  categoryId      Int
  category        ExpenseCategoryMaster @relation(fields: [categoryId], references: [slno])
  description     String
  currencyId      Int
  currency        CurrencyMaster        @relation(fields: [currencyId], references: [slno])
  amount          Float
  bucketType      String                @default("NA") // Lead, Order, Other, NA
  bucketReference String? // Reference number (OrderNo, OppNumber)
  documentPath    String? // Physically mapped file path
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([companyId])
  @@index([userId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  slno        Int       @unique @default(autoincrement())
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  date        DateTime
  startTime   DateTime?
  endTime     DateTime?
  activity    String?
  projectId   String? // Reference an Order Id for project hours
  project     Order?    @relation(fields: [projectId], references: [id])
  hoursWorked Float
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([companyId])
  @@index([userId])
}

// -----------------------------------------------------------------------------
// PURCHASE ORDER WORKFLOW & APPROVALS
// -----------------------------------------------------------------------------

model PoWorkflowMaster {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  isActive  Boolean  @default(true)
  isDelete  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps    PoWorkflowStep[]
  requests PurchaseOrderRequest[]
}

model PoWorkflowStep {
  id              String           @id @default(cuid())
  workflowId      String
  workflow        PoWorkflowMaster @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stepOrder       Int
  userId          String
  user            User             @relation(fields: [userId], references: [id])
  autoActionType  String           @default("NA") // "APPROVE", "CANCEL", "NA"
  autoActionHours Int?
  isActive        Boolean          @default(true)
}

model PurchaseOrderRequest {
  id            String         @id @default(cuid())
  poNumber      String         @unique
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  supplierSlno  Int
  supplier      SupplierMaster @relation(fields: [supplierSlno], references: [slno])
  items         Json // array of item details
  targetDate    DateTime?
  paymentTerms  String?
  justification String?
  attachments   Json?

  status           String           @default("PENDING_APPROVAL") // PENDING_APPROVAL, APPROVED, REJECTED, CANCELLED
  workflowId       String
  workflow         PoWorkflowMaster @relation(fields: [workflowId], references: [id])
  currentStepOrder Int              @default(1)

  rejectedRemarks String?
  resubmittedAt   DateTime?

  createdById String
  createdBy   User     @relation("PoCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  history PoApprovalHistory[]
}

model PoApprovalHistory {
  id          String               @id @default(cuid())
  poRequestId String
  poRequest   PurchaseOrderRequest @relation(fields: [poRequestId], references: [id], onDelete: Cascade)
  stepOrder   Int
  userId      String?
  user        User?                @relation(fields: [userId], references: [id])
  action      String // APPROVED, REJECTED, AUTO_APPROVED, AUTO_CANCELLED, RESUBMITTED
  remarks     String?
  timestamp   DateTime             @default(now())
}
